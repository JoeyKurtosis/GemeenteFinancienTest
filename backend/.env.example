SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# --- IV3 warehouse (read-only) — DEVELOPER ONLY, do not set in production ---------
# The raw municipal finance data. Owned by another team; this app only holds SELECT,
# and Iv3Router keeps Django's migrations away from it.
#
# Deployments must leave this unset. The dashboard is served entirely from the app
# database and never connects here: the data is built ahead of time and shipped as
# the iv3_data fixture. Only sync_iv3_summary needs these, and only when CBS
# publishes — see iv3/management/commands/sync_iv3_summary.py.
IV3_DB_NAME=iv3
IV3_DB_USER=
IV3_DB_PASSWORD=
IV3_DB_HOST=dev.kurtosis.nl
IV3_DB_PORT=5432
IV3_DB_SSLMODE=prefer

# --- App database (auth, sessions, users, support) ------------------------------
# Leave unset for local dev: Django falls back to SQLite (backend/db.sqlite3).
# Set in production to point Django's own tables at RDS.
# APP_DB_SECRET_ARN=arn:aws:secretsmanager:eu-west-1:123456789012:secret:gemeentefinancien/db-AbCdEf
# APP_DB_NAME=gemeentefinancien
# APP_DB_SSLMODE=require
# AWS_REGION=eu-west-1
GEMINI_API_KEY=

